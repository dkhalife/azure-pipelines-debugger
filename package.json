{
  "name": "azure-pipeline-templates-debugger",
  "displayName": "azure-pipeline-templates-debugger",
  "description": "",
  "version": "0.0.1",
  "license": "MIT",
  "publisher": "dkhalife",
  "repository": {
    "type": "git",
    "url": "https://github.com/dkhalife/azure-pipelines-debugger"
  },
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onDebugResolve:yaml",
    "onDebugResolve:azurepipelines",
    "onDebugDynamicConfigurations:yaml",
    "onDebugDynamicConfigurations:azurepipelines"
  ],
  "extensionDependencies": [
    "ms-azure-devops.azure-pipelines"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "breakpoints": [
      {
        "language": "azure-pipelines"
      }
    ],
    "debuggers": [
      {
        "type": "azurepipelines",
        "languages": [
          "azure-pipelines"
        ],
        "label": "Launch",
        "configurationAttributes": {
          "launch": {
            "required": [
              "pipeline"
            ],
            "properties": {
              "pipeline": {
                "type": "string",
                "description": "Absolute path to a text file.",
                "default": "${workspaceFolder}/azure-pipeline.yml"
              },
              "parameters": {
                "type": "string",
                "description": "An optional YAML file containing assignments to parameter values for the pipeline.",
                "default": ""
              },
              "stopOnEntry": {
                "type": "boolean",
                "description": "Automatically stop after launch.",
                "default": false
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "azurepipelines",
            "request": "launch",
            "name": "Azure Pipelines: Debug current file",
            "pipeline": "${file}"
          }
        ],
        "configurationSnippets": [
          {
            "label": "Azure Pipelines: Debug a pipeline",
            "description": "A new configuration for debugging a pipeline.",
            "body": {
              "type": "azurepipelines",
              "request": "launch",
              "name": "Debug pipeline",
              "pipeline": "^\"\\${workspaceFolder}/azure-pipeline.yml\"",
              "stopOnEntry": false
            }
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "yarn run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "yarn run compile && yarn run lint",
    "lint": "eslint src --ext ts",
    "test": "vscode-test",
    "test:unit": "yarn run compile && mocha --ui tdd out/test/expressionEngine/**/*.test.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.13",
    "@types/path-browserify": "^1.0.3",
    "@types/vscode": "^1.109.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^8.57.1",
    "mocha": "^11.7.5",
    "nyc": "^17.1.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@vscode/debugadapter": "^1.68.0",
    "@vscode/debugprotocol": "^1.68.0",
    "await-notify": "^1.0.1",
    "path-browserify": "^1.0.1",
    "yaml": "^2.8.2"
  }
}
